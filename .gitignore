# Node.js (Web Frontend)
web/node_modules/
web/.next/
web/out/
web/.turbo/
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# Docker & Persistence Volumes
# Docker volumes are mapped dynamically, but we block any accidental local folders
postgres_data/
redis_data/
minio_data/

# IDE / Editor Settings
# We commit shared settings (.vscode/settings.json, launch.json, extensions.json)
# but ignore user-specific or history folders
.vscode/workspace.json
.vscode/tasks.json
.vscode/*.log
.idea/
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?
