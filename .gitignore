# System Files
.DS_Store
Thumbs.db
*.tmp
*.bak
*.swp

# Environment Secrets
.env
.env.local
.env.development.local
.env.test.local
.env.production.local
*.env

# Python (Backend & Worker)
__pycache__/
*.py[cod]
*$py.class
*.egg-info/
.eggs/
build/
dist/
.pytest_cache/
.ruff_cache/
.mypy_cache/
.venv/
venv/
ENV/
