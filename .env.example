# Svara AI System Environment Variables
PROJECT_NAME=SvaraAI

# Database (PostgreSQL)
POSTGRES_USER=svara_user
POSTGRES_PASSWORD=svara_secure_pass_123
POSTGRES_DB=svara_db
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
DATABASE_URL=postgresql://svara_user:svara_secure_pass_123@postgres:5432/svara_db

# Cache & Queue (Redis)
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_URL=redis://redis:6379/0

# Object Storage (MinIO / S3)
MINIO_ROOT_USER=svara_minio_admin
MINIO_ROOT_PASSWORD=svara_minio_password_123
MINIO_ENDPOINT=minio:9000
MINIO_EXTERNAL_ENDPOINT=http://localhost:9000
MINIO_USE_SSL=False
MINIO_BUCKET_AUDIO=svara-audio
MINIO_BUCKET_VOICES=svara-voices

# JWT Authentication
JWT_SECRET=super_secret_jwt_key_svara_ai_2026
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=11520 # 8 days

# Web Server & Ports
PORT_BACKEND=8000
PORT_WEB=3000
PORT_NGINX=80
